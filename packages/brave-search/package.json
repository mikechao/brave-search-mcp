{
  "name": "brave-search",
  "type": "module",
  "version": "0.9.0",
  "description": "A fully typed Brave Search API wrapper, providing easy access to web search, local POI search, and automatic polling for web search summary feature.",
  "author": "erik.balfe@protonmail.com",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/erik-balfe/brave-search.git"
  },
  "keywords": [
    "brave",
    "web-search",
    "brave-search",
    "search",
    "api",
    "search-engine",
    "web-search",
    "web-api",
    "search-results",
    "data-retrieval",
    "information-retrieval",
    "internet-search",
    "brave-api",
    "search-integration",
    "web-scraping",
    "data-mining"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint . --ext .ts,.js,.mjs,.cjs --fix",
    "lint:check": "eslint . --ext .ts,.js,.mjs,.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm run lint:check && pnpm run typecheck"
  },
  "dependencies": {},
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@types/node": "^22.13.14",
    "eslint": "^9.39.2",
    "shx": "^0.4.0",
    "typescript": "^5.8.2"
  }
}
